FAL_KEY=your_fal_ai_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
PORT=3001

# Production and security settings
FRONTEND_URL=https://your-production-app.vercel.app
ADMIN_SECRET=your_admin_secret_here

# OpenAI configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_MAX_GENERATIONS=180
OPENAI_DAILY_MAX_GENERATIONS=30
OPENAI_MONTHLY_BUDGET_USD=5
OPENAI_ESTIMATED_COST_PER_IMAGE_USD=0.025
WHATSAPP_LINK=https://wa.me/919999999999

# Supabase Integration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Admin Dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_JWT_SECRET=your-secure-jwt-signing-secret

